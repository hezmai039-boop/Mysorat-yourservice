generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  INDIVIDUAL
  BUSINESS
  EXPERT
  OWNER
}

enum AccountType {
  INDIVIDUAL
  BUSINESS
}

enum OperationStatus {
  PENDING_PAYMENT
  DOCS_REQUIRED
  IN_PROGRESS
  DELAYED
  ESCALATED_TO_EXPERT
  COMPLETED
  CANCELLED
}

enum ExecutorType {
  AUTO
  EXPERT
}

enum StepStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum DocumentStatus {
  PENDING
  UPLOADED
  VERIFIED
  REJECTED
}

enum ChatRole {
  USER
  ASSISTANT
}

enum ContentType {
  TEXT
  VOICE
  IMAGE
}

enum LinkStatus {
  ACTIVE
  BROKEN
  CHECKING
}

enum ActorType {
  AUTO
  EXPERT
  OWNER
  SYSTEM
}

enum CustomerSegment {
  NEW
  REGULAR
  VIP
  AT_RISK
}

enum ServiceAudience {
  CITIZEN
  RESIDENT
  VISITOR
  BUSINESS
}

model User {
  id                String       @id @default(uuid())
  email             String       @unique
  phone             String?      @unique
  passwordHash      String
  role              UserRole     @default(INDIVIDUAL)
  accountType       AccountType?
  isActive          Boolean      @default(true)
  twoFactorEnabled  Boolean      @default(false)
  twoFactorSecret   String?
  segment           CustomerSegment @default(NEW)
  segmentOverridden Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  smsNotificationsEnabled      Boolean  @default(true)
  whatsappNotificationsEnabled Boolean  @default(false)

  // Every user gets a stable referral code at signup. referredById records
  // who brought them in (set once, at registration, never changed).
  // referralRewardGranted is on the REFERRED user, not the referrer - it
  // guards against granting the referrer's reward more than once for the
  // same referral.
  referralCode           String    @unique
  referredById           String?
  referredBy             User?     @relation("Referrals", fields: [referredById], references: [id])
  referrals              User[]    @relation("Referrals")
  referralRewardGranted  Boolean   @default(false)
  // Wallet credit earned from referral rewards - applied against
  // feeAmountSar at payment time, never paid out in cash.
  creditSar              Decimal   @default(0) @db.Decimal(10, 2)

  individualProfile IndividualProfile?
  businessProfile   BusinessProfile?
  expert            Expert?
  operations        Operation[]
  feedback          Feedback[]
  chatMessages      ChatMessage[]
  passwordResetTokens PasswordResetToken[]
  favorites         Favorite[]
  pushSubscriptions PushSubscription[]
  supportRequests   SupportRequest[]

  @@index([role])
  @@index([accountType])
  @@index([segment])
  @@index([referredById])
}

model IndividualProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName    String
  nationalId  String?
  nationality String?
  city        String?
  createdAt   DateTime @default(now())
}

model BusinessProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName  String
  crNumber     String?
  sector       String?
  city         String?
  createdAt    DateTime @default(now())
}

model Expert {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialty String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  operations Operation[]
}

model ServiceCatalog {
  id             String      @id @default(uuid())
  code           String      @unique
  nameAr         String
  nameEn         String
  category       String
  descriptionAr  String?
  targetAudience ServiceAudience[]
  estimatedDays  Int         @default(3)
  // Mysorat's own assistance/automation fee - this is the only amount the
  // platform actually charges the customer.
  platformFeeSar Decimal     @default(0) @db.Decimal(10, 2)
  // Informational estimate of what the government portal itself charges for
  // this transaction. Mysorat never collects this - it is not authorized to
  // take payment on behalf of government agencies - it's shown so the
  // customer knows to expect it when they complete the step on the official
  // portal directly.
  govFeeEstimateSar Decimal  @default(0) @db.Decimal(10, 2)
  requiredDocs   Json        @default("[]")
  active         Boolean     @default(true)
  createdAt      DateTime    @default(now())

  operations     Operation[]
  knowledge      KnowledgeBase[]
  favorites      Favorite[]

  @@index([category])
}

model Operation {
  id                  String          @id @default(uuid())
  userId              String
  user                User            @relation(fields: [userId], references: [id])
  serviceId           String
  service             ServiceCatalog  @relation(fields: [serviceId], references: [id])
  status              OperationStatus @default(PENDING_PAYMENT)
  executorType        ExecutorType    @default(AUTO)
  expertId            String?
  expert              Expert?         @relation(fields: [expertId], references: [id])
  feeAmountSar        Decimal         @default(0) @db.Decimal(10, 2)
  feePaid             Boolean         @default(false)
  // Snapshot of ServiceCatalog.govFeeEstimateSar at creation time - display
  // only, never added to feeAmountSar and never charged by Mysorat.
  govFeeEstimateSar   Decimal         @default(0) @db.Decimal(10, 2)
  // Referral wallet credit actually applied to reduce feeAmountSar at
  // payment time - kept for transparency in the customer's receipt.
  creditAppliedSar    Decimal         @default(0) @db.Decimal(10, 2)
  currentStep         Int             @default(0)
  totalSteps          Int             @default(1)
  expectedCompletionAt DateTime?
  delayed             Boolean         @default(false)
  delayReason         String?
  escalatedAt         DateTime?
  completedAt         DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  steps       OperationStep[]
  documents   Document[]
  feedback    Feedback[]
  auditLogs   AuditLog[]

  @@index([userId])
  @@index([status])
  @@index([expertId])
}

model OperationStep {
  id           String       @id @default(uuid())
  operationId  String
  operation    Operation    @relation(fields: [operationId], references: [id], onDelete: Cascade)
  stepNumber   Int
  titleAr      String
  titleEn      String
  status       StepStatus   @default(PENDING)
  executedBy   ExecutorType @default(AUTO)
  expertNote   String?
  updatedAt    DateTime     @updatedAt
  createdAt    DateTime     @default(now())

  @@unique([operationId, stepNumber])
}

model Document {
  id               String         @id @default(uuid())
  operationId      String
  operation        Operation      @relation(fields: [operationId], references: [id], onDelete: Cascade)
  docType          String
  fileUrl          String?
  status           DocumentStatus @default(PENDING)
  verificationNote String?
  uploadedAt       DateTime?
  createdAt        DateTime       @default(now())
}

model Feedback {
  id           String    @id @default(uuid())
  operationId  String
  operation    Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  rating       Int
  comment      String?
  voiceUrl     String?
  transcribed  Boolean   @default(false)
  ownerReply   String?
  ownerReplyAt DateTime?
  featured     Boolean   @default(false)
  createdAt    DateTime  @default(now())

  @@index([operationId])
  @@index([rating])
  @@index([featured])
}

model GovernmentLink {
  id            String     @id @default(uuid())
  nameAr        String
  nameEn        String
  url           String
  category      String
  status        LinkStatus @default(ACTIVE)
  lastCheckedAt DateTime?
  lastError     String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model ChatMessage {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId   String
  role        ChatRole
  contentType ContentType @default(TEXT)
  content     String
  createdAt   DateTime    @default(now())

  @@index([userId, sessionId])
}

model KnowledgeBase {
  id        String         @id @default(uuid())
  serviceId String
  service   ServiceCatalog @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  key       String
  data      Json
  hitCount  Int            @default(0)
  updatedAt DateTime       @updatedAt
  createdAt DateTime       @default(now())

  @@unique([serviceId, key])
}

model AuditLog {
  id          String    @id @default(uuid())
  operationId String?
  operation   Operation? @relation(fields: [operationId], references: [id], onDelete: SetNull)
  actorType   ActorType
  actorId     String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime  @default(now())

  @@index([operationId])
  @@index([actorType])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Favorite {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceId String
  service   ServiceCatalog @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@unique([userId, serviceId])
  @@index([userId])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

enum SupportRequestStatus {
  OPEN
  ANSWERED
  CLOSED
}

model SupportRequest {
  id           String               @id @default(uuid())
  userId       String
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  message      String
  status       SupportRequestStatus @default(OPEN)
  ownerReply   String?
  ownerReplyAt DateTime?
  createdAt    DateTime             @default(now())

  @@index([userId])
  @@index([status])
}
